{
  "name": "manabi-map-web",
  "private": true,
  "version": "0.3.2",
  "author": "Hiroshi Ishizaka (ishizakahiroshi) <ishizakahiroshi.dev@gmail.com>",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "pnpm fetch:tags && pnpm gen:schools-json && vite build && node scripts/gen-seo-pages.mjs",
    "fetch:tags": "git fetch --tags --depth=1 || true",
    "gen:schools-json": "node scripts/gen-schools-json.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "lint": "oxlint",
    "test": "vitest run && pnpm test:static",
    "test:static": "node --test scripts/verify-static-output.test.mjs",
    "verify:static": "node scripts/verify-static-output.mjs --dist dist --max-file-mib 25",
    "preview": "vite preview"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.0",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "protomaps-leaflet": "^4.0.1",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.18.1",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@ishizakahiroshi/vite-plugin-git-version": "^0.1.0",
    "@tailwindcss/vite": "^4.3.2",
    "@types/leaflet": "^1.9.21",
    "@types/leaflet.markercluster": "^1.5.6",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "oxlint": "^1.71.0",
    "tailwindcss": "^4.3.2",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vitest": "^3.2.4"
  }
}
